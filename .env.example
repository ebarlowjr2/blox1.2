# ============================================================================
# BLOX Multi-Tenant Configuration
# ============================================================================

# Supabase Configuration (required for authentication and database)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# App Configuration
NEXT_PUBLIC_APP_URL=https://blox.onecs.net

# Stripe Configuration (for billing and subscriptions)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
NEXT_PUBLIC_PRICE_MONTHLY=price_xxx
NEXT_PUBLIC_PRICE_ANNUAL=price_yyy

# API Configuration
API_BASE_URL=https://api.blox.onecs.net

# OpenAI Configuration (for chat functionality)
OPENAI_API_KEY=your_openai_api_key

# Twilio Configuration (for SMS functionality)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# AWS Configuration (for Secrets Manager and SES)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# Secrets Manager Configuration
SECRETS_PREFIX=blox/

# Email Configuration (for SES email sending via Tool Gateway)
SES_DOMAIN=bloxmail.com
SES_FROM_EMAIL=noreply@blox.onecs.net

# CrewAI Service Configuration (for multi-agent coordination)
CREW_SERVICE_URL=http://localhost:8001
GATEWAY_URL=https://blox.onecs.net
